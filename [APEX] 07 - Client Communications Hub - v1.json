              "id": "b4",
              "name": "clientEmail",
              "value": "={{ $json.ClientEmail }}",
              "type": "string"
            },
            {
              "id": "b5",
              "name": "matterRef",
              "value": "={{ $json.MatterRef }}",
              "type": "string"
