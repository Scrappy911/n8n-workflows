            {
              "id": "c8",
              "name": "smsBody",
              "value": "=Hi {{ $json.body.clientName }}, update from FIRM_NAME on matter {{ $json.body.matterRef }}: {{ $json.body.milestoneTitle }}. Call FIRM_PHONE for details.",
              "type": "string"
            },
            {
              "id": "c9",
              "name": "emailSubject",
              "value": "=Matter Update: {{ $json.body.milestoneTitle }} — {{ $json.body.matterRef }}",
              "type": "string"
            },
            {
              "id": "c10",
              "name": "emailBody",
              "value": "=Dear {{ $json.body.clientName }},\n\nWe have an update on your matter {{ $json.body.matterRef }}:\n\n{{ $json.body.milestoneTitle }}\n\n{{ $json.body.milestoneDetails }}\n\nPlease do not hesitate to contact us at FIRM_PHONE if you have any questions.\n\nKind regards,\nFIRM_NAME",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
