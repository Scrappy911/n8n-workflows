      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        288,
        608
      ]
    },
    {
      "parameters": {
        "from": "+TWILIO_FROM_NUMBER_PLACEHOLDER",
        "to": "={{ $json.clientPhone }}",
        "message": "={{ $json.smsBody }}",
        "options": {}
      },
