{
  "name": "[APEX] 07 - Client Communications Hub - v1",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours"
            }
          ]
        }
      },
      "id": "wf07-node-01",
      "name": "Hourly Appointment Check",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * 1-5"
            }
          ]
        }
      },
      "id": "wf07-node-02",
      "name": "Daily Deadline Scan",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        304
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "apex-milestone-notification",
        "options": {}
      },
      "id": "wf07-node-03",
      "name": "Milestone Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        608
      ],
      "webhookId": "4312402e-fbc6-47ce-8c78-ccbbac3c9bdf"
    },
    {
      "parameters": {
        "operation": "search",
        "base": {
          "mode": "id",
          "value": "={{AIRTABLE_BASE_ID}}"
        },
        "table": {
          "mode": "id",
          "value": "APPOINTMENTS_TABLE_ID"
        },
        "filterByFormula": "AND(IS_AFTER({AppointmentDateTime}, NOW()), IS_BEFORE({AppointmentDateTime}, DATEADD(NOW(), 48, 'hours')))",
        "options": {}
      },
      "id": "wf07-node-04",
      "name": "Fetch Upcoming Appointments",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        288,
        0
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "airtable_cred",
          "name": "Airtable"
        }
      }
    },
    {
      "parameters": {
        "operation": "search",
        "base": {
          "mode": "id",
          "value": "={{AIRTABLE_BASE_ID}}"
        },
        "table": {
          "mode": "id",
          "value": "DEADLINES_TABLE_ID"
        },
        "filterByFormula": "AND(IS_AFTER({DeadlineDate}, TODAY()), IS_BEFORE({DeadlineDate}, DATEADD(TODAY(), 7, 'days')))",
        "options": {}
      },
      "id": "wf07-node-05",
      "name": "Fetch Upcoming Deadlines",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        288,
        304
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "airtable_cred",
          "name": "Airtable"
        }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a1",
              "name": "notificationType",
              "value": "appointment_reminder",
              "type": "string"
            },
            {
              "id": "a2",
              "name": "clientName",
              "value": "={{ $json.ClientName }}",
              "type": "string"
            },
            {
              "id": "a3",
              "name": "clientPhone",
              "value": "={{ $json.ClientPhone }}",
              "type": "string"
            },
            {
              "id": "a4",
              "name": "clientEmail",
              "value": "={{ $json.ClientEmail }}",
              "type": "string"
            },
            {
              "id": "a5",
              "name": "matterRef",
              "value": "={{ $json.MatterRef }}",
              "type": "string"
            },
            {
              "id": "a6",
              "name": "appointmentDateTime",
              "value": "={{ $json.AppointmentDateTime }}",
              "type": "string"
            },
            {
              "id": "a7",
              "name": "smsBody",
              "value": "=Hi {{ $json.ClientName }}, reminder from FIRM_NAME: appointment on {{ $json.AppointmentDateTime }} (ref: {{ $json.MatterRef }}). To reschedule call FIRM_PHONE.",
              "type": "string"
            },
            {
              "id": "a8",
              "name": "emailSubject",
              "value": "=Appointment Reminder — {{ $json.AppointmentDateTime }}",
              "type": "string"
            },
            {
              "id": "a9",
              "name": "emailBody",
              "value": "=Dear {{ $json.ClientName }},\n\nThis is a reminder of your upcoming appointment:\n\nDate/Time: {{ $json.AppointmentDateTime }}\nMatter Reference: {{ $json.MatterRef }}\n\nTo reschedule please contact us at FIRM_PHONE or FIRM_EMAIL.\n\nKind regards,\nFIRM_NAME",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
