              "id": "b8",
              "name": "smsBody",
              "value": "=Hi {{ $json.ClientName }}, FIRM_NAME: {{ $json.DeadlineType }} deadline on {{ $json.DeadlineDate }} for matter {{ $json.MatterRef }}. Call FIRM_PHONE with questions.",
              "type": "string"
            },
            {
              "id": "b9",
              "name": "emailSubject",
              "value": "=Upcoming Deadline: {{ $json.DeadlineType }} — {{ $json.DeadlineDate }}",
              "type": "string"
            },
            {
              "id": "b10",
              "name": "emailBody",
              "value": "=Dear {{ $json.ClientName }},\n\nA deadline is approaching on your matter:\n\nDeadline Type: {{ $json.DeadlineType }}\nDue Date: {{ $json.DeadlineDate }}\nMatter Reference: {{ $json.MatterRef }}\n\nPlease contact us at FIRM_PHONE if you need to take any action.\n\nKind regards,\nFIRM_NAME",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "wf07-node-07",
      "name": "Format Deadline Alert",
