      "id": "http-06-conflict",
      "name": "Conflict Check LEAP",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        704,
        656
      ]
    },
    {
      "parameters": {
        "jsCode": "const searchResults = $json.clients ?? $json.data ?? [];\nconst clientName = $('Normalize Matter Data').item.json.clientName.toLowerCase();\n\nconst potentialConflicts = searchResults.filter(c => {\n  const name = (c.name ?? c.clientName ?? '').toLowerCase();\n  return name.includes(clientName) || clientName.includes(name);\n});\n\nconst conflictFound = potentialConflicts.some(c =>\n  (c.matters ?? c.activeMatters ?? []).length > 0\n);\n\nreturn [{\n  json: {\n    conflictFound,\n    conflictDetails: potentialConflicts,\n    searchResultCount: searchResults.length\n  }\n}];"
      },
