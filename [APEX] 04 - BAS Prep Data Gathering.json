          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "BAS_CLIENTS_TABLE_ID",
          "mode": "id"
        },
        "filterByFormula": "AND({Active}=TRUE(),{LodgementCycle}=\"Quarterly\")",
        "options": {}
      },
