              "value": "={{ '<ul>' + $json.body.documentsRequired.map(d => '<li>' + d + '</li>').join('') + '</ul>' }}",
              "type": "string"
            },
            {
              "id": "a7",
              "name": "documentsList",
              "value": "={{ $json.body.documentsRequired.join(', ') }}",
              "type": "string"
            },
            {
              "id": "a8",
              "name": "requestedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        },
        "options": {}
