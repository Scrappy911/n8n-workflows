      "webhookId": "ba64383e-4f64-4cd0-92be-3e77782bbd4e"
    },
    {
      "parameters": {
        "sendTo": "={{COMPLIANCE_OFFICER_EMAIL}}",
        "subject": "='Upcoming Deadline: ' + $json.DeadlineTitle + ' — ' + $json.DeadlineDate",
        "message": "='Compliance deadline approaching:\n\nTitle: ' + $json.DeadlineTitle + '\nDue Date: ' + $json.DeadlineDate + '\nDeadline Type: ' + $json.DeadlineType + '\nClient: ' + $json.ClientName + '\nMatter Reference: ' + $json.MatterRef + '\nPriority: ' + $json.Priority + '\nAssigned To: ' + $json.AssignedTo + '\n\nPlease ensure this matter is actioned before the due date.'",
        "options": {}
      },
      "id": "wf09-n11",
      "name": "Send Upcoming Email Alert",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        720,
        464
      ],
      "webhookId": "1c73afcf-d050-4705-9168-8c537674360d",
      "credentials": {
        "gmailOAuth2": {
          "id": "gmail_cred",
          "name": "Gmail"
        }
