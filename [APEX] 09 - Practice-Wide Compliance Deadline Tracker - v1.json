      "typeVersion": 2,
      "position": [
        0,
        912
      ],
      "webhookId": "ca8ffc2b-bfea-4edc-a977-e00847c80414"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "deadlineTitle",
              "value": "={{ $json.body.deadlineTitle }}",
              "type": "string"
            },
            {
              "id": "2",
              "name": "deadlineDate",
              "value": "={{ $json.body.deadlineDate }}",
              "type": "string"
            },
            {
              "id": "3",
              "name": "matterRef",
              "value": "={{ $json.body.matterRef }}",
              "type": "string"
            },
            {
              "id": "4",
              "name": "clientName",
              "value": "={{ $json.body.clientName }}",
              "type": "string"
            },
            {
              "id": "5",
              "name": "priority",
              "value": "={{ $json.body.priority || 'Medium' }}",
              "type": "string"
            },
            {
              "id": "6",
              "name": "assignedTo",
              "value": "={{ $json.body.assignedTo }}",
              "type": "string"
            },
            {
              "id": "7",
              "name": "deadlineType",
              "value": "={{ $json.body.deadlineType }}",
              "type": "string"
            },
            {
              "id": "8",
              "name": "status",
              "value": "Open",
              "type": "string"
            },
            {
              "id": "9",
              "name": "registeredAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "wf09-n05",
      "name": "Format New Deadline",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        240,
        0
      ]
    },
    {
      "parameters": {
        "operation": "create",
        "base": {
          "mode": "id",
          "value": "={{AIRTABLE_BASE_ID}}"
        },
        "table": {
          "mode": "id",
          "value": "COMPLIANCE_DEADLINES_TABLE_ID"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "DeadlineTitle": "={{ $json.deadlineTitle }}",
            "DeadlineDate": "={{ $json.deadlineDate }}",
            "MatterRef": "={{ $json.matterRef }}",
            "ClientName": "={{ $json.clientName }}",
            "Priority": "={{ $json.priority }}",
            "AssignedTo": "={{ $json.assignedTo }}",
            "DeadlineType": "={{ $json.deadlineType }}",
            "Status": "Open",
            "RegisteredAt": "={{ $json.registeredAt }}"
          }
        },
        "options": {}
      },
      "id": "wf09-n06",
      "name": "Register in Airtable",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        480,
        0
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "airtable_cred",
          "name": "Airtable"
        }
      }
    },
    {
      "parameters": {
        "sendTo": "={{COMPLIANCE_OFFICER_EMAIL}}",
        "subject": "='Compliance Deadline Registered: ' + $('Format New Deadline').item.json.deadlineTitle",
        "message": "='A new compliance deadline has been registered in the APEX Tracker.\n\nTitle: ' + $('Format New Deadline').item.json.deadlineTitle + '\nDue Date: ' + $('Format New Deadline').item.json.deadlineDate + '\nDeadline Type: ' + $('Format New Deadline').item.json.deadlineType + '\nMatter Reference: ' + $('Format New Deadline').item.json.matterRef + '\nClient: ' + $('Format New Deadline').item.json.clientName + '\nPriority: ' + $('Format New Deadline').item.json.priority + '\nAssigned To: ' + $('Format New Deadline').item.json.assignedTo + '\n\nPlease log in to the compliance tracker to confirm and manage this deadline.'",
        "options": {}
      },
      "id": "wf09-n07",
      "name": "Send Registration Confirmation",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        720,
        0
      ],
      "webhookId": "5f323582-eabb-4705-9a77-3e27527e1200",
      "credentials": {
        "gmailOAuth2": {
          "id": "gmail_cred",
          "name": "Gmail"
        }
      }
    },
    {
      "parameters": {
        "operation": "search",
        "base": {
          "mode": "id",
          "value": "={{AIRTABLE_BASE_ID}}"
        },
        "table": {
          "mode": "id",
          "value": "COMPLIANCE_DEADLINES_TABLE_ID"
        },
        "filterByFormula": "AND(NOT({Status} = 'Complete'), IS_BEFORE({DeadlineDate}, DATEADD(TODAY(), 3, 'days')))",
        "options": {}
      },
      "id": "wf09-n08",
      "name": "Fetch Overdue & Due Soon Deadlines",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        240,
        304
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "airtable_cred",
          "name": "Airtable"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "1",
              "leftValue": "={{ DateTime.fromISO($json.DeadlineDate) < DateTime.now() }}",
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "wf09-n09",
      "name": "Triage Urgency",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        480,
        304
      ]
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "={{COMPLIANCE_SLACK_CHANNEL_ID}}",
          "mode": "id"
        },
        "text": "='⚠️ OVERDUE COMPLIANCE DEADLINE ⚠️\n\nTitle: ' + $json.DeadlineTitle + '\nWas Due: ' + $json.DeadlineDate + '\nClient: ' + $json.ClientName + '\nMatter: ' + $json.MatterRef + '\nPriority: ' + $json.Priority + '\nAssigned: ' + $json.AssignedTo + '\n\nImmediate action required. Please update the compliance tracker.'",
