    },
    {
      "parameters": {
        "operation": "search",
        "base": {
          "mode": "id",
          "value": "={{AIRTABLE_BASE_ID}}"
        },
        "table": {
          "mode": "id",
          "value": "COMPLIANCE_DEADLINES_TABLE_ID"
        },
        "filterByFormula": "AND(NOT({Status} = 'Complete'), IS_AFTER({DeadlineDate}, DATEADD(TODAY(), -1, 'days')), IS_BEFORE({DeadlineDate}, DATEADD(TODAY(), 8, 'days')))",
        "options": {}
      },
      "id": "wf09-n12",
      "name": "Fetch Week Ahead Deadlines",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        240,
        608
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "airtable_cred",
          "name": "Airtable"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (!items.length) {\n  return [{ json: { digest: 'No open compliance deadlines in the week ahead.', count: 0 } }];\n}\n\nconst lineArray = [];\nfor (const item of items) {\n  const d = item.json;\n  const line = '\\u2022 ' + (d.DeadlineTitle || 'Untitled') + ' \\u2014 Due: ' + (d.DeadlineDate || 'TBC') + ' | Client: ' + (d.ClientName || 'Unknown') + ' | Matter: ' + (d.MatterRef || 'N/A') + ' | Priority: ' + (d.Priority || 'Medium') + ' | Assigned: ' + (d.AssignedTo || 'Unassigned');\n  lineArray.push(line);\n}\n\nconst weekOf = DateTime.now().toFormat('d MMMM yyyy');\nconst digest = 'APEX Practice \\u2014 Weekly Compliance Digest (Week of ' + weekOf + ')\\n\\nOpen deadlines this week: ' + items.length + '\\n\\n' + lineArray.join('\\n') + '\\n\\nAll deadlines must be reviewed and actioned. Contact FIRM_EMAIL with queries.';\n\nreturn [{ json: { digest, count: items.length } }];"
      },
